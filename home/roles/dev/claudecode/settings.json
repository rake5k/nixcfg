    "deny": [
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Read(./.env.*)",
      "Read(*/.local/share/secrets/**)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git push *)",
      "Bash(glab mr approve:*)",
      "Bash(glab mr close:*)",
      "Bash(glab mr delete:*)",
      "Bash(glab mr reopen:*)",
      "Bash(glab mr revoke:*)",
      "Bash(glab mr subscribe:*)",
      "Bash(glab mr unsubscribe:*)",
      "Bash(wget:*)"
