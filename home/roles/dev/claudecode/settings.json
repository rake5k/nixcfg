      "Bash(glab mr list:*)",
      "Bash(glab mr note:*)",
      "Bash(glab mr rebase:*)",
      "Bash(glab mr todo:*)",
      "Bash(glab mr update:*)",
      "Bash(glab mr view:*)",
      "Bash(helm dependency update:*)",
      "Bash(helm template:*)",
      "Bash(ls:*)",
      "Bash(nix develop:*)",
      "Bash(nix eval:*)",
      "Bash(nix flake:*)",
      "Bash(nix fmt:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Skill(blueclaude:glab)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:digicomp.ch)",
      "WebFetch(domain:doc-hub.apps.case.bluecare.ch)",
      "WebFetch(domain:doc-hub.apps.case.bluecare.ch)",
      "WebFetch(domain:docs.ollama.com)",
      "WebFetch(domain:docs.sonarsource.com)",
      "WebFetch(domain:dzone.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:guides.micronaut.io)",
      "WebFetch(domain:javadoc.io)",
      "WebFetch(domain:mvnrepository.com)",
      "WebFetch(domain:numtide.github.io)",
      "WebFetch(domain:openapi-generator.tech)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:spring.io)",
      "WebFetch(domain:springdoc.org)",
      "WebFetch(domain:tecnovy.com)",
      "WebFetch(domain:www.isaqb.org)",
      "WebSearch",
      "mcp__ide__getDiagnostics",
      "mcp__mcp-atlassian__confluence_get_page",
      "mcp__mcp-atlassian__confluence_get_page_children",
      "mcp__mcp-atlassian__jira_get_issue"
